# Copy to deploy/.env and fill in. Never commit deploy/.env.

# --- API auth (fail-closed in prod) ----------------------------------------
AGENTTIC_API_TOKEN=change-me-admin-token

# --- database --------------------------------------------------------------
# Leave empty for SQLite (data volume). For production, BYO-Postgres:
# AGENTTIC_DB=postgresql+psycopg://user:pass@your-host:5432/agenttic
AGENTTIC_DB=

# --- optional multi-worker event bus / rate limiting -----------------------
# AGENTTIC_REDIS_URL=redis://redis:6379/0

# --- bundled Postgres credentials (only if using --profile bundled-db) -----
POSTGRES_USER=agenttic
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agenttic

# --- listen port on the host ----------------------------------------------
AGENTTIC_PORT=8700

# --- pin a published image instead of building locally --------------------
# AGENTTIC_IMAGE=ghcr.io/your-org/agenttic:0.7.0
